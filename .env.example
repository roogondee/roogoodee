# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SECRET=eyJ...

# ─── Claude AI ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Together.xyz (FLUX.1 image generation) ──────────────
TOGETHER_API_KEY=tgp_v1_...

# ─── Pexels (stock photos) ───────────────────────────────
PEXELS_API_KEY=your_pexels_api_key

# ─── WordPress (autopost) ────────────────────────────────
WP_URL=https://rugondee.com
WP_USER=your_wp_username
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── Google Sheets ───────────────────────────────────────
GSHEET_ID=1BxiMVs0XRA5nFMxxxxxxxxxxxxxxxxx
GSHEET_CREDS_JSON={"type":"service_account",...}

# ─── LINE Notify (optional) ──────────────────────────────
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# ─── Facebook Page (autopost + Messenger bot) ───────────
FB_PAGE_ID=1234567890
FB_PAGE_ACCESS_TOKEN=EAAG...   # long-lived Page Access Token
# Random string ใช้ verify webhook ตอน subscribe ที่ Meta Developer Console
# ตั้งเองได้ — ใส่ค่าเดียวกันทั้งที่นี่และที่ webhook config
FB_VERIFY_TOKEN=
# App Secret จาก Meta Developer Console (Basic settings)
# ถ้าตั้งจะเปิด HMAC verification ของ webhook (ป้องกันคนปลอม payload)
# ถ้าเว้นว่าง webhook จะรับทุก request — ไม่แนะนำใน production
FB_APP_SECRET=
SITE_BASE_URL=https://www.roogondee.com

# ─── Analytics ───────────────────────────────────────────
# GA4 measurement ID (e.g. G-XXXXXXXXXX). Auto-injected when set.
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel ID (numeric). Required for FB Lead Ads optimization.
# Fires PageView on every page; Lead + CompleteRegistration on quiz completion.
NEXT_PUBLIC_META_PIXEL_ID=
# TikTok Pixel ID (e.g. CXXXXXXXXXXXXXXX). Fires page() on every page;
# InitiateCheckout on quiz start; SubmitForm + CompleteRegistration on success.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# TikTok Events API (server-side) access token from Events Manager → Settings.
# Required to send server-side events (recovers ~30-50% lost to iOS/ad blockers).
# Server reuses NEXT_PUBLIC_TIKTOK_PIXEL_ID as the Pixel Code.
TIKTOK_ACCESS_TOKEN=
# Optional — paste from Events Manager → Test Events to verify payloads
# before going live. Leave blank in production.
TIKTOK_TEST_EVENT_CODE=

# ─── Google reCAPTCHA v3 (bot protection on quiz) ────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lc...
RECAPTCHA_SECRET_KEY=6Lc...

# ─── Cron (voucher expiry reminders) ─────────────────────
CRON_SECRET=some_long_random_string

# ─── App-level encryption for sensitive data (§8.2) ──────
# STD quiz answers are encrypted with AES-256-GCM at rest.
# Set to 64-char hex (32 bytes) or any passphrase (will be SHA-256d).
ENCRYPTION_KEY=

# ─── LINE Messaging API (OA) ─────────────────────────────
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_NOTIFY_GROUP_ID=
# Bot's own userId — used to detect @mentions in group/room chats.
# Get via: curl -H "Authorization: Bearer $LINE_CHANNEL_ACCESS_TOKEN" https://api.line.me/v2/bot/info
LINE_BOT_USER_ID=

# ─── LIFF (LINE Frontend Framework) ──────────────────────
# LIFF ID จาก LINE Developers Console → Channel → LIFF tab
# ใช้ในเบราว์เซอร์ผ่าน liff.init() บนหน้า /lead/liff เพื่อ capture
# LINE userId เมื่อเปิดจาก in-app browser ของ LINE
NEXT_PUBLIC_LIFF_ID=
